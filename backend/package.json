{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "build": "echo 'Checking for LibreOffice binary...' && if [ ! -d '/opt/render/project/src/backend/libreoffice' ]; then echo 'Downloading portable LibreOffice execution binary...' && mkdir -p libreoffice && curl -L https://github.com/vladgolubev/serverless-libreoffice/releases/download/6.1.0/lo.tar.gz | tar -xz -C ./libreoffice; fi",
    "start": "export PATH=$PATH:$(pwd)/libreoffice/instdir/program && node src/index.js"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.24.1",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "nodemon": "^3.1.14"
  },
  "description": ""
}
